@inject Blazored.Modal.Services.IModalService ModalService
@using Blazored.Modal
@code {
    [CascadingParameter] BlazoredModalInstance BlazoredModal { get; set; }

    private string selectedList = "Default";
    private List<string> vocabLists = new() { "Default", "CyberSociety", "Travel", "Business" };

    private bool enableHints = true;

    private void ApplyOptions()
    {
        // Pass options back to parent page
        var result = new VocabOptions
        {
            SelectedList = selectedList,
            EnableHints = enableHints
        };
        BlazoredModal.CloseAsync(ModalResult.Ok(result));
        
    }

    private void Cancel() => BlazoredModal.CloseAsync(); 
   
}

<div class="options-modal">
    <h2>Vocabulary Options</h2>

    <div class="option-group">
        <label>Select Vocabulary List:</label>
        <select @bind="selectedList" class="options-select">
            @foreach (var list in vocabLists)
            {
                <option value="@list">@list</option>
            }
        </select>
    </div>

    <div class="option-group">
        <label>
            <input type="checkbox" @bind="enableHints" /> Enable Hints
        </label>
    </div>

    <div class="options-buttons">
        <button class="check-button" @onclick="ApplyOptions">Apply</button>
        <button class="end-button" @onclick="Cancel">Cancel</button>
    </div>
</div>

@code {
    public class VocabOptions
    {
        public string SelectedList { get; set; }
        public bool EnableHints { get; set; }
    }
}
<style>
.options-modal {
    padding: 1.5rem;
    background-color: #ffffff;
    border-radius: 12px;
    font-family: 'Segoe UI', Roboto, sans-serif;
    max-width: 400px;
}

.options-modal h2 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
    color: #37493a;
}

.option-group {
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.options-select {
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    border-radius: 8px;
    border: 1px solid #ccc;
}

.options-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
}
</style>